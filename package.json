{
	"name": "attachment-notes",
	"version": "0.12.0",
	"description": "This plugin detects new attachments in the vault and create markdown files with metadata.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"fix:prettier": "prettier --write src",
		"lint:prettier": "prettier --check src",
		"fix": "run-s fix:prettier fix:eslint",
		"fix:eslint": "eslint . --fix",
		"lint": "run-p lint:prettier lint:eslint",
		"lint:eslint": "eslint .",
		"dev": "node esbuild.config.mjs",
		"build": "node esbuild.config.mjs production",
		"css": "true",
		"knip": "knip",
		"preversion": "node version-bump.mjs --preflight",
		"version": "node version-bump.mjs",
		"postversion": "git push origin main --follow-tags --force-with-lease"
	},
	"keywords": [],
	"author": "qawatake",
	"license": "MIT",
	"devDependencies": {
		"@eslint/js": "^9.39.2",
		"@types/node": "^24.10.1",
		"builtin-modules": "^3.3.0",
		"esbuild": "^0.27.3",
		"eslint": "^9.39.2",
		"eslint-plugin-obsidianmd": "^0.1.9",
		"knip": "^5.80.0",
		"npm-run-all": "^4.1.5",
		"obsidian": "^1.11.4",
		"prettier": "^3.7.3",
		"tslib": "^2.8.1",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.52.0"
	},
	"dependencies": {
		"@popperjs/core": "^2.11.0"
	},
	"knip": {
		"entry": ["src/main.ts"],
		"project": ["src/**/*.ts"],
		"ignore": [],
		"ignoreDependencies": ["eslint", "npm-run-all", "prettier"],
		"ignoreBinaries": ["eslint", "knip", "prettier", "run-p", "run-s", "tsc"],
		"ignoreExportsUsedInFile": true
	}
}
